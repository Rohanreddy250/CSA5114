#include <stdio.h>
#include <string.h>

int main() {
    char text[100];
    int key, i;

    printf("Enter plaintext: ");
    scanf("%s", text);

    printf("Enter key (1-25): ");
    scanf("%d", &key);

    printf("Ciphertext: ");

    for(i = 0; text[i] != '\0'; i++) {
        if(text[i] >= 'A' && text[i] <= 'Z')
            printf("%c", ((text[i]-'A'+key)%26)+'A');
        else if(text[i] >= 'a' && text[i] <= 'z')
            printf("%c", ((text[i]-'a'+key)%26)+'a');
        else
            printf("%c", text[i]);
    }

    return 0;
}


