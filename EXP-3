#include <stdio.h>
#include <string.h>

char matrix[5][5]={
{'M','O','N','A','R'},
{'C','H','Y','B','D'},
{'E','F','G','I','K'},
{'L','P','Q','S','T'},
{'U','V','W','X','Z'}
};

void findPosition(char ch,int *row,int *col)
{
    if(ch=='J')
        ch='I';

    for(int i=0;i<5;i++)
    {
        for(int j=0;j<5;j++)
        {
            if(matrix[i][j]==ch)
            {
                *row=i;
                *col=j;
                return;
            }
        }
    }
}

int main()
{
    char p1,p2;
    int r1,c1,r2,c2;

    printf("Enter two uppercase letters: ");
    scanf(" %c%c",&p1,&p2);

    findPosition(p1,&r1,&c1);
    findPosition(p2,&r2,&c2);

    printf("Encrypted Pair: ");

    if(r1==r2)
    {
        printf("%c%c",matrix[r1][(c1+1)%5],matrix[r2][(c2+1)%5]);
    }
    else if(c1==c2)
    {
        printf("%c%c",matrix[(r1+1)%5][c1],matrix[(r2+1)%5][c2]);
    }
    else
    {
        printf("%c%c",matrix[r1][c2],matrix[r2][c1]);
    }

    return 0;
}


